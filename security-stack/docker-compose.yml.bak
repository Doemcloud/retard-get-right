networks:
  security-net:
    driver: bridge
    ipam:
      config:
        - subnet: 172.20.0.0/24

volumes:
  wazuh-data:
  wazuh-logs:
  wazuh-queue:
  wazuh-etc:
  wazuh-var:
  opensearch-data:
  minio-data:
  samba-data:
  suricata-logs:

services:

  wazuh-indexer:
    image: wazuh/wazuh-indexer:4.7.3
    container_name: wazuh-indexer
    hostname: wazuh-indexer
    restart: unless-stopped
    networks:
      security-net:
        ipv4_address: 172.20.0.11
    ports:
      - "9200:9200"
    environment:
      - "OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g"
      - "discovery.type=single-node"
      - "DISABLE_INSTALL_DEMO_CONFIG=true"
      - "DISABLE_SECURITY_PLUGIN=true"
      - "plugins.security.disabled=true"
    volumes:
      - opensearch-data:/var/lib/wazuh-indexer
      - ./config/opensearch.yml:/usr/share/wazuh-indexer/opensearch.yml:ro
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536

  wazuh-manager:
    image: wazuh/wazuh-manager:4.7.3
    container_name: wazuh-manager
    hostname: wazuh-manager
    restart: unless-stopped
    networks:
      security-net:
        ipv4_address: 172.20.0.10
    ports:
      - "1514:1514/udp"
      - "1515:1515"
      - "514:514/udp"
      - "55000:55000"
    environment:
      - INDEXER_URL=http://172.20.0.11:9200
      - INDEXER_USERNAME=admin
      - INDEXER_PASSWORD=admin
      - FILEBEAT_SSL_VERIFICATION_MODE=none
      - API_USERNAME=wazuh
      - API_PASSWORD=SecurePass123!
    volumes:
      - wazuh-logs:/var/ossec/logs
      - wazuh-queue:/var/ossec/queue
      - wazuh-var:/var/ossec/var
    depends_on:
      - wazuh-indexer

  wazuh-dashboard:
    image: wazuh/wazuh-dashboard:4.7.3
    container_name: wazuh-dashboard
    hostname: wazuh-dashboard
    restart: unless-stopped
    networks:
      security-net:
        ipv4_address: 172.20.0.12
    ports:
      - "5601:5601"
    environment:
      - OPENSEARCH_HOSTS=http://172.20.0.11:9200
      - WAZUH_API_URL=http://172.20.0.10:55000
      - DASHBOARD_USERNAME=admin
      - DASHBOARD_PASSWORD=admin
      - SERVER_SSL_ENABLED=false
      - OPENSEARCH_SSL_VERIFICATION_MODE=none
      - OPENSEARCH_USERNAME=admin
      - OPENSEARCH_PASSWORD=admin
      - DISABLE_SECURITY_DASHBOARDS_PLUGIN=true
    volumes:
      - ./config/dashboard/opensearch_dashboards.yml:/usr/share/wazuh-dashboard/config/opensearch_dashboards.yml:ro
    depends_on:
      - wazuh-indexer
      - wazuh-manager

  suricata:
    image: jasonish/suricata:latest
    container_name: suricata
    hostname: suricata
    restart: unless-stopped
    network_mode: host
    cap_add:
      - NET_ADMIN
      - NET_RAW
      - SYS_NICE
    volumes:
      - suricata-logs:/var/log/suricata

  minio:
    image: minio/minio:latest
    container_name: minio
    hostname: minio
    restart: unless-stopped
    networks:
      security-net:
        ipv4_address: 172.20.0.20
    ports:
      - "9000:9000"
      - "9001:9001"
    environment:
      - MINIO_ROOT_USER=minioadmin
      - MINIO_ROOT_PASSWORD=MinioSecure123!
    volumes:
      - minio-data:/data
    command: server /data --console-address ":9001"

  samba-dc:
    image: nowsci/samba-domain:latest
    container_name: samba-dc
    hostname: dc1
    restart: unless-stopped
    networks:
      security-net:
        ipv4_address: 172.20.0.30
    ports:
      - "53:53"
      - "53:53/udp"
      - "88:88"
      - "88:88/udp"
      - "135:135"
      - "139:139"
      - "389:389"
      - "389:389/udp"
      - "445:445"
      - "464:464"
      - "636:636"
      - "3268:3268"
      - "3269:3269"
    environment:
      - DOMAIN=SECURITY
      - DOMAINPASS=Admin@SecurePass123
      - REALM=SECURITY.LOCAL
      - DNSFORWARDER=8.8.8.8
      - HOSTIP=172.20.0.30
      - NOCOMPLEXITY=false
    volumes:
      - samba-data:/var/lib/samba
    cap_add:
      - SYS_ADMIN
    privileged: true
