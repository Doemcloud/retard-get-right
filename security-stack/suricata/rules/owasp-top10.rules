# ═══════════════════════════════════════════════════════════
# SURICATA RULES — OWASP TOP 10 PROTECTION
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────
# A01 — Broken Access Control
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A01 - Path Traversal Attack"; flow:established,to_server; content:"../"; http_uri; pcre:"/(\.\.[\/\\]){2,}/U"; classtype:web-application-attack; sid:9000001; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A01 - Path Traversal URL Encoded"; flow:established,to_server; content:"%2e%2e%2f"; nocase; http_uri; classtype:web-application-attack; sid:9000002; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A01 - Forced Browsing Admin Panel"; flow:established,to_server; pcre:"/\/(admin|administrator|wp-admin|phpmyadmin|manager\/html)/Ui"; http_uri; classtype:web-application-attack; sid:9000003; rev:1;)

# ─────────────────────────────────────
# A02 — Cryptographic Failures
# ─────────────────────────────────────
alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02 - SSLv2 Weak Protocol"; ssl_version:2; classtype:policy-violation; sid:9000010; rev:1;)

alert tls $EXTERNAL_NET any -> $HOME_NET any (msg:"OWASP A02 - SSLv3 Weak Protocol (POODLE)"; ssl_version:3; classtype:policy-violation; sid:9000011; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A02 - Sensitive Data in URL (password)"; flow:established,to_server; pcre:"/[?&](password|passwd|pwd|secret|token|api_key)=/Ui"; http_uri; classtype:policy-violation; sid:9000012; rev:1;)

# ─────────────────────────────────────
# A03 — Injection
# ─────────────────────────────────────

# SQL Injection
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - SQL Injection UNION SELECT"; flow:established,to_server; pcre:"/union.{0,20}select/Ui"; http_uri; classtype:web-application-attack; sid:9000020; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - SQL Injection OR 1=1"; flow:established,to_server; pcre:"/(\bor\b.{0,10}1\s*=\s*1|\bor\b.{0,10}'[^']*'\s*=\s*'[^']*')/Ui"; http_client_body; classtype:web-application-attack; sid:9000021; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - SQL Injection DROP TABLE"; flow:established,to_server; pcre:"/drop\s+table/Ui"; http_client_body; classtype:web-application-attack; sid:9000022; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - SQL Injection Blind Time-Based"; flow:established,to_server; pcre:"/sleep\s*\(\s*\d+\s*\)|waitfor\s+delay|benchmark\s*\(/Ui"; http_client_body; classtype:web-application-attack; sid:9000023; rev:1;)

# Command Injection
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - Command Injection Attempt"; flow:established,to_server; pcre:"/[;&|`]\s*(cat|ls|id|whoami|uname|wget|curl|bash|sh|python|perl|nc|netcat)\b/U"; http_client_body; classtype:web-application-attack; sid:9000024; rev:1;)

# LDAP Injection
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - LDAP Injection Attempt"; flow:established,to_server; pcre:"/(\*\)\(|\)\(|\(\||\|\()/U"; http_client_body; classtype:web-application-attack; sid:9000025; rev:1;)

# XML/XXE Injection
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A03 - XXE Injection Attempt"; flow:established,to_server; content:"<!ENTITY"; http_client_body; classtype:web-application-attack; sid:9000026; rev:1;)

# ─────────────────────────────────────
# A05 — Security Misconfiguration
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A05 - Sensitive File Access .env"; flow:established,to_server; content:"/.env"; http_uri; classtype:web-application-attack; sid:9000040; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A05 - Git Repository Exposure"; flow:established,to_server; content:"/.git/"; http_uri; classtype:web-application-attack; sid:9000041; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A05 - Backup File Access"; flow:established,to_server; pcre:"/\.(bak|backup|old|orig|save|swp|tmp)$/Ui"; http_uri; classtype:web-application-attack; sid:9000042; rev:1;)

# ─────────────────────────────────────
# A07 — Authentication Failures
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A07 - HTTP Auth Brute Force"; flow:established,to_server; content:"Authorization: Basic"; http_header; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-user; sid:9000060; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A07 - Login Brute Force POST"; flow:established,to_server; content:"POST"; http_method; pcre:"/(login|signin|auth|authenticate)/Ui"; http_uri; threshold:type threshold, track by_src, count 10, seconds 60; classtype:attempted-user; sid:9000061; rev:1;)

# ─────────────────────────────────────
# A08 — Software Integrity Failures
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A08 - Deserialization Attack Java"; flow:established,to_server; content:"rO0AB"; http_client_body; classtype:web-application-attack; sid:9000070; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A08 - PHP Object Injection"; flow:established,to_server; pcre:"/O:\d+:\"[^\"]+\":\d+:\{/U"; http_client_body; classtype:web-application-attack; sid:9000071; rev:1;)

# ─────────────────────────────────────
# A10 — SSRF
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A10 - SSRF AWS Metadata"; flow:established,to_server; content:"169.254.169.254"; http_client_body; classtype:web-application-attack; sid:9000090; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A10 - SSRF Localhost Access"; flow:established,to_server; pcre:"/https?:\/\/(localhost|127\.0\.0\.1|0\.0\.0\.0|::1)/Ui"; http_client_body; classtype:web-application-attack; sid:9000091; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP A10 - SSRF Internal Network"; flow:established,to_server; pcre:"/https?:\/\/(10\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.168\.)/Ui"; http_client_body; classtype:web-application-attack; sid:9000092; rev:1;)

# ─────────────────────────────────────
# XSS (Cross-Site Scripting)
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP XSS - Script Tag Injection"; flow:established,to_server; pcre:"/<script[^>]*>/Ui"; http_client_body; classtype:web-application-attack; sid:9000100; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP XSS - JavaScript Event Handler"; flow:established,to_server; pcre:"/\bon(error|load|click|mouseover|focus|blur)\s*=/Ui"; http_client_body; classtype:web-application-attack; sid:9000101; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"OWASP XSS - JavaScript Protocol"; flow:established,to_server; content:"javascript:"; nocase; http_client_body; classtype:web-application-attack; sid:9000102; rev:1;)

# ─────────────────────────────────────
# SCANNING & RECON
# ─────────────────────────────────────
alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"RECON - Web Scanner Nikto"; flow:established,to_server; content:"Nikto"; http_user_agent; classtype:web-application-attack; sid:9000200; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"RECON - Web Scanner sqlmap"; flow:established,to_server; content:"sqlmap"; nocase; http_user_agent; classtype:web-application-attack; sid:9000201; rev:1;)

alert http $EXTERNAL_NET any -> $HTTP_SERVERS $HTTP_PORTS (msg:"RECON - Web Scanner Nmap"; flow:established,to_server; content:"Nmap Scripting Engine"; http_user_agent; classtype:web-application-attack; sid:9000202; rev:1;)

# ─────────────────────────────────────
# SAMBA / AD ATTACKS
# ─────────────────────────────────────
alert smb $EXTERNAL_NET any -> $DC_SERVERS any (msg:"AD ATTACK - SMB Brute Force"; flow:established,to_server; threshold:type threshold, track by_src, count 5, seconds 30; classtype:attempted-user; sid:9000300; rev:1;)

alert dns $EXTERNAL_NET any -> $DNS_SERVERS 53 (msg:"AD ATTACK - DNS Zone Transfer Attempt"; dns.query; content:"|00 FC|"; classtype:attempted-recon; sid:9000301; rev:1;)
